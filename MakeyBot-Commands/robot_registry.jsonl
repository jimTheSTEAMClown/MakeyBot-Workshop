              "unit": "ms",
              "range": "500-10000",
              "default": 1000
            }
          }
        },
        "set_eye_pulse": {
          "type": "object",
          "description": "Rhythmic heartbeat-style fade in and out on both eyes",
          "keys": {
            "active": {
              "type": "boolean",
              "default": false
            },
            "rate": {
              "type": "integer",
