            "max_brightness": {
              "type": "integer",
              "unit": "percent",
              "range": "0-100",
              "default": 100
            }
          }
        },
        "set_eye_color_shift": {
          "type": "object",
          "description": "One-time smooth transition between two colors on both eyes",
          "keys": {
            "active": {
              "type": "boolean",
              "default": false
            },
            "color_from": {
              "type": "rgb_list_or_string",
              "description": "Starting color as [R,G,B] or the string 'random'",
              "default": [
                0,
                0,
                0
              ]
            },
            "color_to": {
              "type": "rgb_list_or_string",
              "description": "Ending color as [R,G,B] or the string 'random'",
              "default": [
                255,
                255,
                255
              ]
            },
            "duration": {
              "type": "integer",
              "unit": "ms",
              "range": "500-10000",
              "default": 2000
            }
          }
        },
        "set_eye_color_cycle": {
          "type": "object",
          "description": "Continuously loops through a list of colors on both eyes",
          "keys": {
            "active": {
              "type": "boolean",
              "default": false
            },
            "colors": {
              "type": "list_of_rgb_lists",
              "description": "List of 2-10 RGB colors to cycle through",
              "min_colors": 2,
              "max_colors": 10,
              "default": [
