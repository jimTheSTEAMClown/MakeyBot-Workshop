    "stop_light": {
      "command_spec": {
        "traffic": {
          "description": "Rule-based signal behavior. sub_mode is required. cycle_settings only required when sub_mode is cycle.",
          "sub_mode": {
            "type": "string",
            "options": [
              "stop",
              "caution",
              "go",
              "cycle"
            ],
            "descriptions": {
              "stop": "blinking red only, interval 500ms, duration 250ms",
              "caution": "blinking yellow only, interval 750ms, duration 375ms",
              "go": "solid green only",
              "cycle": "auto-sequences red to yellow to green to yellow and back"
            }
          },
          "cycle_settings": {
            "red_duration": {
              "type": "integer",
              "unit": "ms",
              "range": "1000-30000",
              "default": 5000
            },
            "yellow_duration": {
              "type": "integer",
              "unit": "ms",
              "range": "500-10000",
              "default": 2000
            },
            "green_duration": {
              "type": "integer",
              "unit": "ms",
              "range": "1000-30000",
              "default": 5000
            }
          }
        },
        "freeform": {
          "description": "Direct independent control of each LED. mode is the single source of truth for each LED.",
          "red_led": {
            "mode": {
              "type": "string",
              "options": [
                "on",
                "off",
                "blink",
                "strobe",
                "fade",
                "pulse",
                "dim",
                "morse_message"
              ],
              "description": "Single source of truth for this LED. Only one behavior active at a time."
            },
            "blink": {
              "type": "object",
              "required_when_mode": "blink",
              "keys": {
                "interval": {
                  "type": "integer",
                  "unit": "ms",
                  "range": "100-10000"
                },
                "duration": {
                  "type": "integer",
                  "unit": "ms",
                  "range": "50-5000"
                },
                "random": {
                  "type": "boolean"
                },
                "random_min_interval": {
                  "type": "integer",
                  "unit": "ms",
                  "range": "10000-60000"
                },
                "random_max_interval": {
                  "type": "integer",
                  "unit": "ms",
                  "range": "10000-60000"
                }
              }
            },
            "strobe": {
              "type": "object",
              "required_when_mode": "strobe",
              "keys": {
                "speed": {
                  "type": "integer",
                  "unit": "ms",
                  "range": "50-500"
                },
                "duration": {
                  "type": "integer",
                  "unit": "ms",
                  "range": "500-10000"
                }
              }
            },
            "fade": {
              "type": "object",
              "required_when_mode": "fade",
              "description": "Ramps LED brightness using PWM. Set up and/or down to control direction. If both are true the LED fades up then down continuously. Requires PWMLED.",
              "keys": {
                "up": {
                  "type": "boolean",
                  "default": true,
                  "description": "If true, ramp from off to full brightness."
                },
                "down": {
                  "type": "boolean",
                  "default": false,
                  "description": "If true, ramp from full brightness to off. If both up and down are true, the fade cycles up then down."
                },
                "duration": {
                  "type": "integer",
                  "unit": "ms",
                  "range": "100-10000",
                  "default": 1000,
                  "description": "Time for each direction (up or down). A full up+down cycle takes 2x this value."
                },
                "loop": {
                  "type": "boolean",
                  "default": true,
                  "description": "If true, repeats continuously. If false, runs once and holds final state."
                }
              }
            },
            "pulse": {
              "type": "object",
              "required_when_mode": "pulse",
              "description": "Rhythmic brightness animation using PWM. The pattern controls the shape of the waveform. Rate scales the overall speed. Requires PWMLED.",
              "keys": {
                "pattern": {
                  "type": "string",
                  "default": "sine",
                  "options": [
                    "sine",
                    "heart",
                    "breathe",
                    "flutter",
                    "alert",
                    "bounce"
                  ],
                  "descriptions": {
                    "sine": "Default smooth continuous rise-and-fall sine wave.",
                    "heart": "Double-beat lub-dub: quick rise, partial fall, rise again, then a long rest.",
                    "breathe": "Very slow inhale-hold-exhale-hold cycle. Calm and meditative.",
                    "flutter": "Fast organic flicker with irregular cadence. Candle or flame feel.",
                    "alert": "Sharp single flash followed by a long dark pause. Alarm or warning.",
                    "bounce": "Ramps up quickly then decays in diminishing steps, like a dropped ball."
                  }
                },
                "rate": {
                  "type": "integer",
                  "unit": "ms",
                  "range": "200-10000",
                  "default": 1000,
                  "description": "Duration of one full pattern cycle in ms. Acts as a speed multiplier for all patterns."
                },
                "min_brightness": {
                  "type": "integer",
                  "unit": "percent",
                  "range": "0-100",
                  "default": 0
                },
                "max_brightness": {
                  "type": "integer",
                  "unit": "percent",
                  "range": "0-100",
                  "default": 100
                },
                "loop": {
                  "type": "boolean",
                  "default": true,
                  "description": "If true, repeats continuously. If false, runs once and holds final state."
                }
              }
            },
            "dim": {
              "type": "object",
              "required_when_mode": "dim",
              "description": "Holds the LED at a fixed PWM brightness level. Requires PWMLED.",
              "keys": {
                "brightness": {
                  "type": "integer",
                  "unit": "percent",
                  "range": "1-99",
                  "default": 50,
                  "description": "Fixed brightness level as a percentage. 0=off, 100=on (use those modes instead)."
                }
              }
            },
            "morse_message": {
              "type": "object",
              "required_when_mode": "morse_message",
              "description": "Flashes any text message in Morse code. Dot/dash timing is calculated from wpm. Loops continuously.",
              "keys": {
                "message": {
                  "type": "string",
                  "description": "The text message to transmit in Morse code. Unsupported characters are skipped.",
                  "default": "SOS"
                },
                "wpm": {
                  "type": "integer",
                  "unit": "words per minute",
                  "range": "1-30",
                  "default": 5,
                  "description": "Transmission speed. Standard PARIS method: 1 wpm = dot duration of 240ms."
                },
                "loop": {
                  "type": "boolean",
                  "default": true,
                  "description": "If true, repeats the message continuously. If false, transmits once."
                }
              }
            }
          },
