                  255,
                  0
                ],
                [
                  0,
                  0,
                  255
                ]
              ]
            },
            "speed": {
              "type": "integer",
              "unit": "ms",
              "range": "100-5000",
              "default": 1000
            },
            "loop": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "set_lock_left_to_right_eye": {
          "type": "boolean",
          "description": "When true, left eye mirrors all right eye commands",
          "default": false
        },
        "set_eye_random_color": {
          "type": "object",
