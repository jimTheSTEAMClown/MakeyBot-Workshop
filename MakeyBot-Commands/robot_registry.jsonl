        "set_eye_strobe": {
          "type": "object",
          "description": "Rapid continuous flicker creating a visual strobe effect on both eyes",
          "keys": {
            "active": {
              "type": "boolean",
              "default": false
            },
            "speed": {
              "type": "integer",
              "unit": "ms",
              "range": "50-500",
