              "type": "object",
              "required_when_mode": "pulse",
              "description": "Rhythmic brightness animation using PWM. The pattern controls the shape of the waveform. Rate scales the overall speed. Requires PWMLED.",
              "keys": {
                "pattern": {
                  "type": "string",
                  "default": "sine",
                  "options": [
                    "sine",
                    "heart",
                    "breathe",
                    "flutter",
                    "alert",
                    "bounce"
                  ],
                  "descriptions": {
                    "sine": "Default smooth continuous rise-and-fall sine wave.",
                    "heart": "Double-beat lub-dub: quick rise, partial fall, rise again, then a long rest.",
                    "breathe": "Very slow inhale-hold-exhale-hold cycle. Calm and meditative.",
                    "flutter": "Fast organic flicker with irregular cadence. Candle or flame feel.",
                    "alert": "Sharp single flash followed by a long dark pause. Alarm or warning.",
                    "bounce": "Ramps up quickly then decays in diminishing steps, like a dropped ball."
                  }
                },
                "rate": {
                  "type": "integer",
                  "unit": "ms",
                  "range": "200-10000",
                  "default": 1000,
                  "description": "Duration of one full pattern cycle in ms. Acts as a speed multiplier for all patterns."
                },
                "min_brightness": {
                  "type": "integer",
                  "unit": "percent",
                  "range": "0-100",
                  "default": 0
                },
                "max_brightness": {
                  "type": "integer",
                  "unit": "percent",
                  "range": "0-100",
                  "default": 100
                },
                "loop": {
                  "type": "boolean",
                  "default": true,
                  "description": "If true, repeats continuously. If false, runs once and holds final state."
                }
              }
            },
            "dim": {
              "type": "object",
              "required_when_mode": "dim",
              "description": "Holds the LED at a fixed PWM brightness level. Requires PWMLED.",
              "keys": {
                "brightness": {
                  "type": "integer",
                  "unit": "percent",
                  "range": "1-99",
                  "default": 50,
                  "description": "Fixed brightness level as a percentage. 0=off, 100=on (use those modes instead)."
                }
              }
            },
            "morse_message": {
              "type": "object",
              "required_when_mode": "morse_message",
              "description": "Flashes any text message in Morse code. Dot/dash timing is calculated from wpm. Loops continuously.",
              "keys": {
                "message": {
                  "type": "string",
                  "description": "The text message to transmit in Morse code. Unsupported characters are skipped.",
                  "default": "SOS"
                },
                "wpm": {
                  "type": "integer",
                  "unit": "words per minute",
                  "range": "1-30",
                  "default": 5,
                  "description": "Transmission speed. Standard PARIS method: 1 wpm = dot duration of 240ms."
                },
                "loop": {
                  "type": "boolean",
                  "default": true,
                  "description": "If true, repeats the message continuously. If false, transmits once."
                }
              }
            }
          }
        },
        "off": {
          "description": "All LEDs off. No additional settings required."
        }
      },
      "default_state": {
        "mode": "off"
      }
    },
    "servo": {
      "command_spec": {},
      "default_state": {}
    }
  }
}